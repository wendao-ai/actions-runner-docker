# 复制为 .env 后填入真实值；.env 切勿提交到 git
# GitHub: Settings → Actions → Runners → New self-hosted runner 获取 token（约 1 小时有效）
RUNNER_URL=https://github.com/wendao-ai
RUNNER_NAME=kb-windows-pc-docker
RUNNER_LABELS=self-hosted,linux,x64,docker

# 每个 runner 需独立 token（token 一次性消耗）
RUNNER_TOKEN=replace-with-fresh-registration-token
RUNNER_TOKEN_2=replace-with-fresh-registration-token
RUNNER_TOKEN_3=replace-with-fresh-registration-token
RUNNER_TOKEN_4=replace-with-fresh-registration-token

# 构建参数（可选）
RUNNER_VERSION=2.334.0
# APT_MIRROR=http://mirrors.tuna.tsinghua.edu.cn/ubuntu
# DOCKER_MIRROR=https://mirrors.aliyun.com/docker-ce/linux/ubuntu
